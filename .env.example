# Resolve · environment variables (example)
# Copy to .env for local dev. .env is gitignored.
#
# NOTE: Vars prefixed VITE_ are embedded in the public client bundle at build
# time. They are NOT secret. Real secrets (the CAPI access token) live only on
# the Cloudflare Worker. In production, the VITE_ values are injected by the
# GitHub Actions build step from repository Secrets (see .github/workflows/deploy.yml).

# --- Meta Pixel (client-side) ---
# Pixel ID from: Resolve Meta Ads V2 account -> Events Manager -> Data Sources
# -> your Pixel -> Settings. Leave blank to ship the site with the Pixel inert.
VITE_META_PIXEL_ID=

# Endpoint the form posts the Lead to for the Conversions API relay.
# Default (same-origin) works when the Cloudflare Worker is routed at
# resolveproperty.ca/api/meta-capi. If you deploy the Worker to a *.workers.dev
# URL instead, set the full https URL here.
VITE_META_CAPI_ENDPOINT=/api/meta-capi

# --- Meta Conversions API (server-side) ---
# These are Cloudflare Worker SECRETS, not VITE_ vars, and never enter the
# bundle. Set them on the Worker, not here:
#   cd workers/meta-capi
#   wrangler secret put META_PIXEL_ID
#   wrangler secret put META_CAPI_ACCESS_TOKEN
# Access token from: Events Manager -> Pixel -> Settings -> Conversions API
# -> Generate access token.

# --- Meta domain verification ---
# Code from: Business Settings -> Brand Safety -> Domains -> add resolveproperty.ca.
# Paste it into the <meta name="facebook-domain-verification"> tag in index.html
# (it is hardcoded there with a TODO placeholder, not read from env).
# META_DOMAIN_VERIFICATION_CODE=

# --- Google Analytics 4 + Google Ads (optional, existing scaffold) ---
VITE_GA_MEASUREMENT_ID=
VITE_GOOGLE_ADS_ID=
VITE_GOOGLE_ADS_CONVERSION_LABEL=
